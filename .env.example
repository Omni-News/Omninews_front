# Google Sign-In Configuration
# Google Cloud Console에서 OAuth 2.0 Client ID 발급
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_SERVER_CLIENT_ID=your-google-server-client-id-here

# Kakao Login Configuration
# Kakao Developers에서 Native App Key 발급
# https://developers.kakao.com/
KAKAO_APP_KEY=your-kakao-app-key-here
